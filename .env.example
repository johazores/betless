# PostgreSQL database used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/betless?schema=public"

# Clerk authentication. Create these in the Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED="true"

# Dedicated admin panel. Set these before first admin login; the first matching
# login creates a SUPER_ADMIN account. Rotate real secrets outside source control.
ADMIN_BOOTSTRAP_EMAIL="root@betless.com"
ADMIN_BOOTSTRAP_PASSWORD="Admin@123"
ADMIN_JWT_SECRET="5d4b1c9f8a2e7d3c6f1a9b8e4d7c2f5a8e1b6c9d4f7a2e5b8c1d6f9a3e7b4c2"
ADMIN_CONFIG_ENCRYPTION_KEY="c8e4f1a7d2b9c5e1f6a3d8b4c7e2a9f5d1b6c3e8f4a7b2d9e5c1f8a6d3b7e4c9"
# Stellar on-chain settlement (optional). Leave empty to run fully off-chain.
# Run `npm run stellar:setup` to create testnet accounts and print these values.
STELLAR_NETWORK="testnet"
STELLAR_ASSET_CODE="PHPC"
STELLAR_ASSET_ISSUER=""
STELLAR_TREASURY_SECRET=""
STELLAR_OPS_SECRET=""
# STELLAR_HORIZON_URL="" # optional override
