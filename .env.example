# PostgreSQL database used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/betless?schema=public"

# Clerk authentication. Create these in the Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED="true"

# Stellar on-chain settlement (optional). Leave empty to run fully off-chain.
# Run `npm run stellar:setup` to create testnet accounts and print these values.
STELLAR_NETWORK="testnet"
STELLAR_ASSET_CODE="PHPC"
STELLAR_ASSET_ISSUER=""
STELLAR_TREASURY_SECRET=""
STELLAR_OPS_SECRET=""
# STELLAR_HORIZON_URL="" # optional override
