# PostgreSQL database used by Prisma. Replace with your local/test database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/betless?schema=public"

# Clerk authentication. Create these in the Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED="true"

# Public Stellar Horizon testnet endpoint. This is not secret.
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"

# Optional server-side testnet signer for live network receipts.
# Leave empty for demo receipts. Never expose this value to the frontend.
STELLAR_PROOF_SOURCE_SECRET=""
