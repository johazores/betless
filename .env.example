# PostgreSQL database used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/betless?schema=public"

# Clerk authentication. Create these in the Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED="true"

# Stellar network. Use TESTNET for development and PUBLIC for mainnet.
STELLAR_NETWORK="TESTNET"
NEXT_PUBLIC_STELLAR_NETWORK="TESTNET"

# Optional override. If omitted, the app picks the correct Horizon URL for the active network.
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"

# Optional override for the Friendbot funding endpoint (testnet/futurenet only).
# If omitted, the testnet Friendbot is used automatically and mainnet funding is disabled.
STELLAR_FRIENDBOT_URL="https://friendbot.stellar.org"

# Optional server-side signer for submitting network receipts.
# Never expose this value to the frontend. Must be a funded account on the active network.
STELLAR_PROOF_SOURCE_SECRET=""

# Optional milestone reward rate override (defaults to 0.01). Also configurable via the AppConfig table.
REWARD_RATE="0.01"
