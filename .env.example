# Public site URL for SEO, Open Graph previews, and canonical links (no trailing slash).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# PostgreSQL database used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/betless?schema=public"

# Clerk authentication.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED="true"

# Dedicated admin panel. Generate unique values for every environment.
# Password: use a password manager.
# JWT secret: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Encryption key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_BOOTSTRAP_EMAIL="admin@example.com"
ADMIN_BOOTSTRAP_PASSWORD="replace-with-a-unique-password"
ADMIN_JWT_SECRET="replace-with-a-random-secret"
ADMIN_CONFIG_ENCRYPTION_KEY="replace-with-a-random-32-byte-base64-key"

# Stellar settlement. Local UI work may leave these empty. Any deployment
# presented as on-chain must configure every required value and use testnet.
STELLAR_NETWORK="testnet"
STELLAR_ASSET_CODE="PHPC"
STELLAR_ASSET_ISSUER=""
STELLAR_TREASURY_SECRET=""
STELLAR_OPS_SECRET=""
# STELLAR_HORIZON_URL=""

# Proposed Instawards multisignature policy. The current ops account remains the
# first signer. The two additional approver public keys must be controlled
# separately and must not be loaded into the web application process.
STELLAR_APPROVER_B_PUBLIC_KEY=""
STELLAR_APPROVER_C_PUBLIC_KEY=""

# Scheduled vault sweeper. Set a random value and send it only in the
# Authorization header used by the scheduler.
CRON_SECRET=""
