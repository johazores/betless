{
  "name": "betless",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "npm run verify:mvp",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "tsx --test tests/*.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "build:next": "next build",
    "verify:mvp": "node scripts/verify-mvp.mjs",
    "audit:instawards": "node scripts/audit-instawards.mjs",
    "check": "npm run typecheck && npm test && npm run verify:mvp && npm run audit:instawards",
    "db:reset": "prisma migrate reset",
    "db:reset:force": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "stellar:setup": "node scripts/setup-stellar-testnet.mjs",
    "stellar:smoke": "tsx --env-file=.env scripts/smoke-stellar.ts",
    "demo:seed": "tsx --env-file=.env scripts/seed-demo.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.16",
    "@prisma/client": "^6.19.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "next": "^16.2.10",
    "prisma": "^6.19.0",
    "react": "^19.1.2",
    "react-dom": "^19.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
