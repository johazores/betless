generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  isSecret  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppUser {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String?
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vaults      Vault[]
  receipts    ProofReceipt[]

  @@index([createdAt])
}

model Vault {
  id               String          @id @default(cuid())
  appUserId        String
  walletAddress    String
  displayName      String?
  mode             VaultMode       @default(ONE_TIME_LOCK)

  targetAmount     Decimal
  currentAmount    Decimal         @default(0)
  topUpAmount      Decimal?
  topUpFrequency   TopUpFrequency?

  durationWeeks    Int
  rewardType       String
  rewardRate       Decimal         @default(0.01)
  reason           String?
  status           VaultStatus     @default(ACTIVE)

  stellarBalanceId String?
  stellarStatus    StellarStatus   @default(NOT_CREATED)

  unlockAt         DateTime
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  appUser          AppUser         @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  rewards          RewardClaim[]
  topUps           TopUp[]
  receipts         ProofReceipt[]

  @@index([appUserId, status, createdAt])
  @@index([walletAddress])
}

enum VaultMode {
  ONE_TIME_LOCK
  PERIODIC_TOP_UP
}

enum TopUpFrequency {
  WEEKLY
  MONTHLY
}

enum VaultStatus {
  ACTIVE
  UNLOCK_READY
  COMPLETED
  CANCELLED
}

enum StellarStatus {
  NOT_CREATED
  PENDING
  CREATED
  FAILED
}

model TopUp {
  id        String      @id @default(cuid())
  vaultId   String
  amount    Decimal
  dueAt     DateTime
  paidAt    DateTime?
  status    TopUpStatus @default(PENDING)
  createdAt DateTime    @default(now())

  vault     Vault       @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId, status, dueAt])
}

enum TopUpStatus {
  PENDING
  COMPLETED
  MISSED
}

model RewardClaim {
  id          String       @id @default(cuid())
  vaultId     String
  weekNumber  Int
  rewardName  String
  rewardValue Decimal
  voucherCode String?
  status      RewardStatus @default(LOCKED)
  claimedAt   DateTime?
  createdAt   DateTime     @default(now())

  vault       Vault        @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@unique([vaultId, weekNumber])
  @@index([vaultId, status, weekNumber])
}

enum RewardStatus {
  LOCKED
  AVAILABLE
  CLAIMED
}

model ProofReceipt {
  id              String             @id @default(cuid())
  appUserId       String
  vaultId         String
  status          ProofReceiptStatus @default(DEMO_RECEIPT)
  network         String             @default("Stellar Testnet")
  publicAddress   String
  proofReference  String             @unique
  transactionHash String?
  operationId     String?
  ledger          Int?
  memo            String?
  explorerUrl     String?
  message         String
  createdAt       DateTime           @default(now())

  appUser         AppUser            @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  vault           Vault              @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([appUserId, createdAt])
  @@index([vaultId, createdAt])
  @@index([transactionHash])
}

enum ProofReceiptStatus {
  DEMO_RECEIPT
  NETWORK_CONFIRMED
  FAILED
}
