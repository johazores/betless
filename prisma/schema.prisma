generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppUser {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String?
  displayName String?
  // Shareable invite code, assigned the first time the user opens the referral card.
  referralCode String? @unique
  // Set once when the user claims a friend's code; enforces the one-claim-per-user rule.
  referredById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  referredBy AppUser?  @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals  AppUser[] @relation("Referrals")

  vaults             Vault[]
  pointsTransactions PointsTransaction[]
}

model Vault {
  id         String      @id @default(cuid())
  appUserId  String
  principal  Decimal
  lockMonths Int
  status     VaultStatus @default(ACTIVE)
  startAt    DateTime    @default(now())
  maturesAt  DateTime

  // Set when the vault closes (maturity or early withdrawal).
  closedAt       DateTime?
  withdrawalFee  Decimal?
  returnedAmount Decimal?

  // On-chain anchor point: the claimable balance holding this vault's principal.
  claimableBalanceId String? @unique

  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appUser            AppUser             @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  pointsTransactions PointsTransaction[]
  stellarOperations  StellarOperation[]

  @@index([appUserId, status, createdAt])
}

/// Outbox for on-chain writes. Intent is recorded before submission so a crash
/// or network failure never loses track of money movement.
model StellarOperation {
  id      String                @id @default(cuid())
  vaultId String
  kind    StellarOperationKind
  state   StellarOperationState @default(PENDING)

  amount             Decimal
  claimableBalanceId String?
  // Signed envelope + expected hash are persisted before first submission so
  // retries and confirmation checks are idempotent.
  xdr          String?
  txHash       String? @unique
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vault Vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId, kind])
  @@index([state, createdAt])
}

enum StellarOperationKind {
  LOCK
  CLAIM_MATURITY
  CLAIM_EARLY
}

enum StellarOperationState {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

enum VaultStatus {
  ACTIVE
  MATURED
  WITHDRAWN_EARLY
}

model PointsTransaction {
  id        String                @id @default(cuid())
  appUserId String
  vaultId   String?
  type      PointsTransactionType
  // Positive for rewards earned, negative for redemptions. 1 point = 1 PHP.
  points      Int
  // 1-based month number of the lock period; used to make monthly accrual idempotent.
  monthIndex  Int?
  rewardName  String?
  voucherCode String?
  description String
  createdAt   DateTime @default(now())

  appUser AppUser @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  vault   Vault?  @relation(fields: [vaultId], references: [id], onDelete: SetNull)

  @@unique([vaultId, monthIndex])
  @@index([appUserId, createdAt])
}

enum PointsTransactionType {
  MONTHLY_REWARD
  REDEMPTION
  REFERRAL_BONUS
}
